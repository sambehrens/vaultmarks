{
  "name": "vaultmarks-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build && cd dist && zip -r ../vaultmarks.zip .",
    "build:firefox": "vite build && cp public/manifest.firefox.json dist/manifest.json && cd dist && zip -r ../vaultmarks-firefox.zip .",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "loro-wasm": "^1.0.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.300",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  }
}
