{
  "manifest_version": 3,
  "name": "Vaultmarks Bookmark Syncing",
  "version": "0.1.0",
  "description": "Zero-knowledge end-to-end encrypted, conflict-free, offline ready, cross-browser bookmark synchronization.",
  "permissions": [
    "bookmarks",
    "storage",
    "identity",
    "alarms"
  ],
  "host_permissions": ["https://api.vaultmarks.com/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vaultmarks",
    "default_icon": {
      "16": "assets/icon-signedout-16.png",
      "48": "assets/icon-signedout-48.png",
      "128": "assets/icon-signedout-128.png"
    }
  },
  "commands": {
    "next-profile": {
      "suggested_key": { "default": "Alt+Shift+J" },
      "description": "Switch to next profile"
    },
    "prev-profile": {
      "suggested_key": { "default": "Alt+Shift+K" },
      "description": "Switch to previous profile"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
